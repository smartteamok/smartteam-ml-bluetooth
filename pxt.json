{
    "name": "smartteam-ml-bluetooth",
    "version": "0.2.0",
    "description": "Bloques en español para recibir por Bluetooth las clases detectadas por el entrenador SmartTEAM ML (requiere micro:bit V2)",
    "license": "MIT",
    "dependencies": {
        "core": "*",
        "bluetooth": "*"
    },
    "yotta": {
        "config": {
            "microbit-dal": {
                "bluetooth": {
                    "open": 1
                }
            }
        }
    },
    "files": [
        "README.md",
        "main.ts"
    ],
    "testFiles": [
        "test.ts"
    ],
    "supportedTargets": [
        "microbit"
    ],
    "preferredEditor": "tsprj"
}
